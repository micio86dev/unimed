{
  "name": "unimed",
  "version": "0.1.0",
  "private": true,
  "description": "UniMed — University admission test preparation platform (monorepo)",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @unimed/frontend dev",
    "build": "pnpm --filter @unimed/frontend build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @unimed/frontend typecheck",
    "test:fe": "pnpm --filter @unimed/frontend test",
    "test:e2e": "pnpm --filter @unimed/frontend test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "*.{js,ts,vue,jsx,tsx,json,css}": ["biome check --write --no-errors-on-unmatched"]
  }
}
